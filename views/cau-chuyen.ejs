<!DOCTYPE html>
<html lang="vi">
<head>
<%- include('partials/head', { title: 'Về Rosé', desc: 'Portfolio chính thức của Rosé Wedding: những gương mặt đã tin chọn, những concept độc bản và cách chúng tôi làm nghề.' }) %>
</head>
<body>
<%- include('partials/header', { solidHeader: true }) %>

<main id="main">
<section class="page-hero">
  <div class="wrap center">
    <span class="eyebrow">Về Rosé Wedding</span>
    <h1>Rosé, qua <span class="italic">từng trang</span></h1>
    <p>Những gương mặt đã tin chọn, những concept độc bản và cách chúng tôi làm nghề. Mời bạn thong thả lật từng trang.</p>
  </div>
</section>

<% if (portfolio.length) { %>
<!-- PORTFOLIO: mỗi trang một khung tràn màn hình -->
<section class="portfolio-pages" id="gallery" aria-label="Portfolio Rosé Wedding">
  <% portfolio.forEach((p, i) => { %>
  <figure class="reveal">
    <img <%= i === 0 ? 'fetchpriority="high"' : 'loading="lazy"' %> src="<%= p %>" alt="Portfolio Rosé Wedding, trang <%= i + 1 %> trên <%= portfolio.length %>" tabindex="0" />
  </figure>
  <% }) %>
</section>

<!-- Lightbox -->
<div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Xem trang portfolio phóng to" hidden>
  <button class="lb-close" id="lbClose" aria-label="Đóng">&times;</button>
  <button class="lb-prev" id="lbPrev" aria-label="Trang trước">&lsaquo;</button>
  <img id="lbImg" src="" alt="" />
  <button class="lb-next" id="lbNext" aria-label="Trang sau">&rsaquo;</button>
  <div class="lb-count" id="lbCount"></div>
</div>
<% } %>

<section class="cta-band reveal">
  <div class="wrap center">
    <h2>Để chúng tôi kể <span class="italic">câu chuyện của bạn?</span></h2>
    <a href="/#booking" class="btn btn-gold mt-24">Đặt lịch tư vấn miễn phí</a>
  </div>
</section>
</main>
<%- include('partials/footer') %>
</body>
</html>
