<footer>
  <div class="wrap">
    <div class="foot">
      <div class="foot-brand">
        <div class="brand serif">Rosé Wedding</div>
        <div class="foot-tagline"><%= s.tagline %></div>
        <% if (s.slogan) { %><p class="foot-slogan">&ldquo;<%= s.slogan %>&rdquo;</p><% } %>
        <div class="foot-social">
          <a href="<%= s.facebook %>" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5.02 3.66 9.18 8.44 9.94v-7.03H7.9v-2.91h2.54V9.85c0-2.52 1.49-3.91 3.78-3.91 1.09 0 2.24.2 2.24.2v2.47h-1.26c-1.24 0-1.63.78-1.63 1.57v1.88h2.78l-.45 2.91h-2.33V22c4.78-.76 8.44-4.92 8.44-9.94Z"/></svg>
            <span>Facebook</span>
          </a>
          <a href="<%= s.instagram %>" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 8.75A3.25 3.25 0 1 0 15.25 12 3.25 3.25 0 0 0 12 8.75Zm0 4.9A1.65 1.65 0 1 1 13.65 12 1.65 1.65 0 0 1 12 13.65ZM16.6 6.35a1.05 1.05 0 1 0 1.05 1.05 1.05 1.05 0 0 0-1.05-1.05ZM12 4.6c2.41 0 2.69.01 3.64.05a4.99 4.99 0 0 1 1.67.31 2.98 2.98 0 0 1 1.73 1.73 4.99 4.99 0 0 1 .31 1.67c.04.95.05 1.23.05 3.64s-.01 2.69-.05 3.64a4.99 4.99 0 0 1-.31 1.67 2.98 2.98 0 0 1-1.73 1.73 4.99 4.99 0 0 1-1.67.31c-.95.04-1.23.05-3.64.05s-2.69-.01-3.64-.05a4.99 4.99 0 0 1-1.67-.31 2.98 2.98 0 0 1-1.73-1.73 4.99 4.99 0 0 1-.31-1.67C4.61 14.69 4.6 14.41 4.6 12s.01-2.69.05-3.64a4.99 4.99 0 0 1 .31-1.67 2.98 2.98 0 0 1 1.73-1.73 4.99 4.99 0 0 1 1.67-.31C9.31 4.61 9.59 4.6 12 4.6M12 3c-2.44 0-2.75.01-3.71.05a6.6 6.6 0 0 0-2.18.42 4.58 4.58 0 0 0-2.64 2.64 6.6 6.6 0 0 0-.42 2.18C3.01 9.25 3 9.56 3 12s.01 2.75.05 3.71a6.6 6.6 0 0 0 .42 2.18 4.58 4.58 0 0 0 2.64 2.64 6.6 6.6 0 0 0 2.18.42C9.25 20.99 9.56 21 12 21s2.75-.01 3.71-.05a6.6 6.6 0 0 0 2.18-.42 4.58 4.58 0 0 0 2.64-2.64 6.6 6.6 0 0 0 .42-2.18c.04-.96.05-1.27.05-3.71s-.01-2.75-.05-3.71a6.6 6.6 0 0 0-.42-2.18 4.58 4.58 0 0 0-2.64-2.64 6.6 6.6 0 0 0-2.18-.42C14.75 3.01 14.44 3 12 3Z"/></svg>
            <span>Instagram</span>
          </a>
          <% if (s.zalo) { %>
          <a href="https://zalo.me/<%= s.zalo.replace(/\D/g, '') %>" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 3C6.48 3 2 6.94 2 11.8c0 2.64 1.33 5 3.44 6.61-.09.76-.4 2.03-1.31 3.09 0 0 1.97-.13 3.64-1.36.72.17 1.47.26 2.23.26 5.52 0 10-3.94 10-8.8S17.52 3 12 3Zm-3.9 11.9a.9.9 0 0 1 0-1.8h2.1l-2.6-3.63a.9.9 0 0 1 .73-1.42h3.57a.9.9 0 0 1 0 1.8h-1.82l2.6 3.63a.9.9 0 0 1-.73 1.42H8.1Zm8.3-.02a2.4 2.4 0 1 1 0-4.8 2.4 2.4 0 0 1 0 4.8Zm0-1.5a.9.9 0 1 0 0-1.8.9.9 0 0 0 0 1.8Z"/></svg>
            <span>Zalo</span>
          </a>
          <% } %>
          <% if (s.tiktok) { %>
          <a href="<%= s.tiktok %>" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1Z"/></svg>
            <span>TikTok</span>
          </a>
          <% } %>
          <% if (s.youtube) { %>
          <a href="<%= s.youtube %>" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.5 6.19a3.02 3.02 0 0 0-2.12-2.14C19.5 3.55 12 3.55 12 3.55s-7.5 0-9.38.5A3.02 3.02 0 0 0 .5 6.19C0 8.07 0 12 0 12s0 3.93.5 5.81a3.02 3.02 0 0 0 2.12 2.14c1.88.5 9.38.5 9.38.5s7.5 0 9.38-.5a3.02 3.02 0 0 0 2.12-2.14C24 15.93 24 12 24 12s0-3.93-.5-5.81ZM9.55 15.57V8.43L15.82 12Z"/></svg>
            <span>YouTube</span>
          </a>
          <% } %>
        </div>
      </div>
      <div>
        <h4>Khám phá</h4>
        <a href="/cau-chuyen">Câu Chuyện</a>
        <a href="/anh-cuoi">Ảnh Cưới</a>
        <a href="/vay-cuoi">Váy Cưới</a>
        <a href="/phong-su">Phóng Sự</a>
        <a href="/tin-tuc">Tin Tức</a>
        <a href="/bang-gia/anh-cuoi">Bảng Giá</a>
      </div>
      <div>
        <h4>Liên hệ</h4>
        <a href="tel:<%= s.hotline_tel %>">Hotline <%= s.hotline %></a>
        <a href="tel:<%= s.cskh_tel %>">CSKH <%= s.cskh %></a>
        <a href="mailto:<%= s.email %>"><%= s.email %></a>
        <span class="foot-line"><%= s.address %></span>
      </div>
    </div>
    <div class="copy">
      <span>© <%= new Date().getFullYear() %> <%= s.site_name %>. All rights reserved.</span>
      <span>Studio mở cửa <%= s.hours %></span>
    </div>
  </div>
</footer>

<!-- Nút liên hệ nhanh nổi (Gọi / Zalo / Messenger) -->
<div class="quick-dock" aria-label="Liên hệ nhanh">
  <a class="qd qd-call" href="tel:<%= s.hotline_tel %>" aria-label="Gọi <%= s.hotline %>" title="Gọi <%= s.hotline %>">
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
  </a>
  <% if (s.zalo) { %>
  <a class="qd qd-zalo" href="https://zalo.me/<%= s.zalo.replace(/\D/g, '') %>" target="_blank" rel="noopener" aria-label="Chat Zalo" title="Chat Zalo">Zalo</a>
  <% } %>
  <% if (s.messenger) { %>
  <a class="qd qd-mess" href="<%= s.messenger %>" target="_blank" rel="noopener" aria-label="Chat Messenger" title="Chat Messenger">
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.14 2 11.25c0 2.88 1.42 5.45 3.63 7.14V22l3.33-1.83c.95.26 1.96.4 3.04.4 5.52 0 10-4.14 10-9.25S17.52 2 12 2zm1.03 12.41l-2.49-2.66-4.87 2.66 5.36-5.69 2.55 2.66 4.81-2.66-5.36 5.69z"/></svg>
  </a>
  <% } %>
</div>

<script src="/js/main.js?v=<%= v %>" defer></script>
