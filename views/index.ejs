<!DOCTYPE html>
<html lang="vi">
<head>
<% let heroFirst = ''; try { heroFirst = JSON.parse(s.hero_images || '[]')[0] || ''; } catch (e) {} %>
<%- include('partials/head', { title: '', desc: '', preload: heroFirst }) %>
</head>
<body>
<%- include('partials/header') %>

<main id="main">

<!-- HERO -->
<section class="hero" id="home">
  <div id="slides" data-images='<%- s.hero_images %>'></div>
  <div class="hero-inner">
    <span class="eyebrow gold">Rosé Wedding · Hà Nội</span>
    <h1><span class="nw">Lưu giữ chuyện tình</span><br/><span class="italic nw">vượt thời gian</span></h1>
    <p><%= s.slogan %></p>
    <div class="hero-cta">
      <a href="#booking" class="btn btn-gold">Đặt lịch tư vấn</a>
      <a href="#anh-cuoi" class="btn btn-light">Xem bộ sưu tập</a>
    </div>
    <div class="hero-line" aria-hidden="true"></div>
  </div>
  <div class="dots" id="dots" role="tablist" aria-label="Chọn ảnh nền"></div>
</section>

<!-- CÂU CHUYỆN -->
<section class="pad" id="about">
  <div class="wrap about-row reveal">
    <div class="about-ph single">
      <figure><img loading="lazy" src="<%= s.about_img_1 %>" alt="Cô dâu Rosé Wedding trong sắc hồng phấn đặc trưng" /></figure>
    </div>
    <div class="about-tx">
      <span class="eyebrow">Câu chuyện của chúng tôi</span>
      <h2>Chúng tôi kể chuyện tình yêu, không chỉ chụp ảnh cưới</h2>
      <p>Phong cách chủ đạo của Rosé Wedding là minimalism, đó là sự tối giản, tinh thần editorial và vẻ đẹp quiet luxury. Ít chi tiết thừa, nhường chỗ cho cảm xúc và màu sắc khác biệt làm nên dấu ấn riêng của mỗi cặp đôi.</p>
    </div>
  </div>
  <div class="wrap about-row rev reveal">
    <div class="about-ph duo">
      <figure><img loading="lazy" src="<%= s.about_img_2 %>" alt="Khoảnh khắc tự nhiên của cặp đôi" /></figure>
      <figure><img loading="lazy" src="<%= s.about_img_3 %>" alt="Ảnh cưới phong cách editorial" /></figure>
    </div>
    <div class="about-tx">
      <p>Văn hoá của chúng tôi là lấy khách hàng làm trọng tâm. Trước khi bấm máy, chúng tôi lắng nghe về cách hai người gặp nhau, về điều khiến cả hai thấy là chính mình, để mỗi khung hình không chỉ đẹp mà còn thật.</p>
      <p>Đội ngũ Rosé đồng hành tận tâm từ buổi tư vấn đầu tiên, qua ngày chụp, đến lúc trao tận tay album cuối cùng. Bởi điều ở lại sau ngày cưới không phải là một buổi chụp, mà là cảm xúc bạn giữ được suốt nhiều năm sau.</p>
      <div class="sign">Thắng Hoàng<small>Founder</small></div>
      <% if (s.about_stats) { %><div class="about-stats"><%= s.about_stats %></div><% } %>
      <a href="/cau-chuyen" class="btn mt-24">Đọc câu chuyện của Rosé</a>
    </div>
  </div>
</section>

<!-- KHÁCH HÀNG VIP / NGƯỜI NỔI TIẾNG (dải đen) -->
<% if (vips.length) { %>
<section class="pad dark" id="khach-hang">
  <div class="wrap">
    <div class="sec-head center reveal">
      <span class="eyebrow">Niềm tin gửi trao</span>
      <h2>Được người nổi tiếng tin chọn</h2>
      <p>Một vài gương mặt thân quen đã chọn Rosé để lưu giữ ngày trọng đại của mình.</p>
    </div>
    <div class="vip-carousel reveal">
      <button class="vip-nav prev" id="vipPrev" aria-label="Xem khách trước">&lsaquo;</button>
      <div class="vip-track" id="vipTrack">
        <% vips.forEach(v => { %>
        <% if (v.album_slug) { %>
        <a class="vip-card" href="/album/<%= v.album_slug %>">
          <img loading="lazy" src="<%= v.image %>" alt="<%= v.name %>" style="object-position:<%= v.pos || '50% 50%' %>" />
          <div class="meta">
            <div class="t"><%= v.tag %></div><h3><%= v.name %></h3>
            <% if (v.quote) { %><p class="q">&ldquo;<%= v.quote %>&rdquo;</p><% } %>
          </div>
        </a>
        <% } else { %>
        <div class="vip-card">
          <img loading="lazy" src="<%= v.image %>" alt="<%= v.name %>" style="object-position:<%= v.pos || '50% 50%' %>" />
          <div class="meta">
            <div class="t"><%= v.tag %></div><h3><%= v.name %></h3>
            <% if (v.quote) { %><p class="q">&ldquo;<%= v.quote %>&rdquo;</p><% } %>
          </div>
        </div>
        <% } %>
        <% }) %>
      </div>
      <button class="vip-nav next" id="vipNext" aria-label="Xem khách sau">&rsaquo;</button>
    </div>
  </div>
</section>
<% } %>

<!-- ẢNH CƯỚI -->
<section class="pad bg-pearl" id="anh-cuoi">
  <div class="wrap">
    <div class="sec-head center reveal">
      <span class="eyebrow">Bộ sưu tập</span>
      <h2>Ảnh Cưới</h2>
      <p>Mỗi concept là một câu chuyện riêng. Chọn một phong cách để bước vào trọn vẹn không gian của bộ ảnh.</p>
    </div>
    <div class="albums-grid">
      <% weddingAlbums.forEach(a => { %>
      <a class="album-card reveal" href="/album/<%= a.slug %>">
        <img loading="lazy" src="<%= a.cover.thumb || a.cover.file %>" alt="<%= a.name %>" style="object-position:<%= a.cover.pos || '50% 50%' %>" />
        <div class="meta">
          <div class="t"><%= a.tag %></div>
          <h3><%= a.name %></h3>
          <div class="go">Xem bộ sưu tập&ensp;&rsaquo;</div>
        </div>
      </a>
      <% }) %>
    </div>
    <div class="center mt-48 reveal"><a href="/anh-cuoi" class="btn">Xem tất cả bộ sưu tập</a></div>
  </div>
</section>

<!-- CONCEPT ĐỘC BẢN -->
<section class="pad signature" id="doc-ban">
  <div class="wrap">
    <div class="sec-head center reveal">
      <span class="eyebrow">Sáng tạo từ gốc rễ Việt Nam</span>
      <h2>Concept Độc Bản</h2>
      <p>Có những vẻ đẹp không thể vay mượn. Rosé không Việt hoá concept của người khác, mà lắng nghe di sản của chính mình rồi kể lại bằng ngôn ngữ thời trang cưới đương đại. Mỗi bộ sưu tập độc bản là một lát cắt văn hoá Việt, được dệt nên chỉ một lần và chỉ có tại Rosé.</p>
    </div>
    <div class="sig-grid">
      <% signatureAlbums.forEach(a => { %>
      <a class="sig-card reveal" href="/album/<%= a.slug %>">
        <img loading="lazy" src="<%= a.cover.file %>" alt="<%= a.name %>" style="object-position:<%= a.cover.pos || '50% 50%' %>" />
        <div class="meta">
          <div class="t"><%= a.tag %></div>
          <h3><%= a.name %></h3>
          <p><%= a.desc.split('. ')[0] %>.</p>
          <div class="go">Khám phá concept&ensp;&rsaquo;</div>
        </div>
      </a>
      <% }) %>
    </div>
  </div>
</section>

<!-- QUY TRÌNH ĐỒNG HÀNH -->
<section class="pad" id="quy-trinh">
  <div class="wrap">
    <div class="sec-head center reveal">
      <span class="eyebrow">Trải nghiệm dịch vụ</span>
      <h2>Quy trình đồng hành cùng bạn</h2>
      <p class="one-line">Một hành trình được thiết kế để bạn luôn yên tâm, từ lần nhắn tin đầu tiên đến khi nhận album.</p>
    </div>
    <div class="steps reveal">
      <div class="st"><div class="n">01</div><h3>Tư vấn 1-1 tại studio</h3><p>Lắng nghe nhu cầu, xem album thật, thử váy thực tế và chọn concept phù hợp với hai bạn.</p></div>
      <div class="st"><div class="n">02</div><h3>Chuẩn bị &amp; đồng hành</h3><p>Lập nhóm riêng cùng ekip trước ngày chụp, gửi checklist chuẩn bị, nhắc lịch và giải đáp mọi lo lắng.</p></div>
      <div class="st"><div class="n">03</div><h3>Ngày chụp trọn vẹn</h3><p>Được đón tiếp chu đáo, chăm sóc xuyên suốt, ekip chỉnh dáng tinh tế để bạn thoải mái là chính mình.</p></div>
      <div class="st"><div class="n">04</div><h3>Hậu kỳ định hướng</h3><p>Thống nhất tone màu theo phong cách bạn thích, tinh chỉnh đến khi ưng ý, cập nhật tiến độ đều đặn.</p></div>
      <div class="st"><div class="n">05</div><h3>Bàn giao &amp; chăm sóc</h3><p>Trao album đóng gói trang trọng kèm thiệp viết tay, và tiếp tục đồng hành cho những cột mốc sau này.</p></div>
    </div>
  </div>
</section>

<!-- VÁY CƯỚI -->
<section class="feature" id="vay-cuoi">
  <div class="ph"><img loading="lazy" src="<%= s.feature_vay_img %>" alt="Cô dâu Rosé trong váy cưới cao cấp" /></div>
  <div class="tx reveal">
    <span class="eyebrow">Váy cưới &amp; Trang phục</span>
    <h2>Kho váy cưới lộng lẫy, đa dạng</h2>
    <p>Bộ sưu tập váy cưới được tuyển chọn và đầu tư liên tục theo xu hướng, từ thiết kế tối giản tinh khôi đến những chiếc đầm dạ hội kiêu sa. Luôn có một bộ váy tôn trọn vóc dáng và tone da của bạn.</p>
    <p>Cô dâu được tư vấn 1-1 cùng stylist, thử váy thực tế tại studio và phối makeup đồng bộ cho từng concept. Nhiều gói cho phép chọn hai look hoàn toàn khác nhau giữa studio và ngoại cảnh.</p>
    <a href="/vay-cuoi" class="btn mt-14">Khám phá váy cưới</a>
  </div>
</section>

<!-- PHIM CƯỚI -->
<section class="pad bg-pearl" id="video">
  <div class="wrap">
    <div class="sec-head center reveal">
      <span class="eyebrow">Phim cưới</span>
      <h2>Những thước phim tình yêu</h2>
      <p>Bên cạnh ảnh, chúng tôi kể chuyện bằng chuyển động và âm thanh, để cảm xúc ngày cưới được sống lại trọn vẹn.</p>
    </div>
    <div class="video-grid reveal">
      <% videos.forEach(v => { %>
      <div>
        <div class="v"><iframe loading="lazy" src="https://www.youtube.com/embed/<%= v.youtube_id %>" title="<%= v.title %>" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div>
        <div class="cap"><%= v.title %></div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- PHÓNG SỰ -->
<section class="feature" id="phong-su">
  <div class="tx reorder reveal">
    <span class="eyebrow">Phóng sự cưới</span>
    <h2>Trọn vẹn cảm xúc ngày trọng đại</h2>
    <p>Phóng sự cưới ghi lại những khoảnh khắc chân thật nhất của ngày cưới, từ giây phút chuẩn bị, ánh mắt rưng rưng của cha mẹ, đến lời hẹn ước trao nhau. Không dàn dựng, chỉ có cảm xúc thật.</p>
    <p>Ekip di chuyển linh hoạt, bắt trọn từng chi tiết nhỏ để nhiều năm sau, mỗi lần xem lại là một lần được sống trong ngày hạnh phúc ấy.</p>
    <a href="/album/phong-su" class="btn mt-14">Xem album phóng sự</a>
  </div>
  <div class="ph"><img loading="lazy" src="<%= s.feature_phongsu_img %>" alt="Khoảnh khắc phóng sự cưới chân thật" /></div>
</section>

<!-- BẢNG GIÁ -->
<section class="pad bg-pearl" id="bang-gia">
  <div class="wrap">
    <div class="sec-head center reveal">
      <span class="eyebrow">Bảng giá</span>
      <h2>Gói dịch vụ <span class="amp">&amp;</span> Báo giá</h2>
      <p>Mức giá được thiết kế linh hoạt theo nhu cầu thật của bạn. Chọn một nhóm dịch vụ để xem báo giá chi tiết.</p>
    </div>
    <div class="price-cards reveal">
      <% const numerals = ['I','II','III','IV','V','VI']; pricing.forEach((p, i) => { %>
      <a href="/bang-gia/<%= p.slug %>">
        <span class="pi"><%= numerals[i] %></span>
        <h3><%= p.name.replace('Báo Giá ', '').replace('Chụp ', '') %></h3>
        <p><%= p.tag %></p>
        <span class="go">Xem báo giá&ensp;&rsaquo;</span>
      </a>
      <% }) %>
    </div>
    <p class="pricing-note center reveal">Báo giá minh bạch theo từng hạng mục, cam kết không phát sinh chi phí ngoài thoả thuận.</p>
  </div>
</section>

<%- include('partials/booking') %>

</main>
<%- include('partials/footer') %>
</body>
</html>
