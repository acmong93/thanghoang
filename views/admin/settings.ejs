<%- include('partials/top', { t: 'Cài đặt' }) %>

<h1>Cài đặt website</h1>

<form method="post" action="/admin/settings" class="panel grid-form">
  <label>Tên website <input name="site_name" value="<%= s.site_name %>" /></label>
  <label>Tagline <input name="tagline" value="<%= s.tagline %>" /></label>
  <label class="full">Tên miền chính thức (cho SEO: canonical, sitemap, chia sẻ mạng xã hội)
    <input name="site_url" value="<%= s.site_url || '' %>" placeholder="VD: https://rosewedding.vn" />
  </label>
  <label class="full">Slogan <input name="slogan" value="<%= s.slogan || '' %>" placeholder="VD: Chỉn chu, sáng tạo và màu sắc khác biệt" /></label>
  <label class="full">Dòng số liệu dưới phần Câu chuyện (để trống thì ẩn)
    <input name="about_stats" value="<%= s.about_stats || '' %>" placeholder="VD: 500+ cặp đôi tin chọn · 2 concept độc bản · Từ 2019" />
  </label>
  <label>Hotline (hiển thị) <input name="hotline" value="<%= s.hotline %>" /></label>
  <label>Hotline (số gọi) <input name="hotline_tel" value="<%= s.hotline_tel %>" /></label>
  <label>CSKH (hiển thị) <input name="cskh" value="<%= s.cskh %>" /></label>
  <label>CSKH (số gọi) <input name="cskh_tel" value="<%= s.cskh_tel %>" /></label>
  <label>Email <input name="email" value="<%= s.email %>" /></label>
  <label>Giờ mở cửa <input name="hours" value="<%= s.hours %>" /></label>
  <label class="full">Địa chỉ studio <input name="address" value="<%= s.address %>" /></label>
  <label>Instagram <input name="instagram" value="<%= s.instagram %>" /></label>
  <label>Facebook <input name="facebook" value="<%= s.facebook %>" /></label>
  <label class="full">Link nhúng Google Maps <input name="map_embed" value="<%= s.map_embed %>" /></label>
  <label class="full">Ghi chú bảng giá <textarea name="pricing_note" rows="2"><%= s.pricing_note %></textarea></label>
  <div class="row-btns"><button type="submit" class="ad-btn primary">Lưu cài đặt</button></div>
</form>

<h2>Ảnh trên trang chủ</h2>
<div class="panel">
  <p class="muted" style="margin-bottom:14px">Bấm vào ảnh muốn thay → chọn ảnh mới từ máy tính. Ảnh tự nén WebP và cập nhật ngay lên web.</p>
  <%
    let heroArr = [];
    try { heroArr = JSON.parse(s.hero_images || '[]'); } catch (e) {}
    const slots = heroArr.map((img, i) => ({ key: 'hero_' + i, label: 'Ảnh nền đầu trang ' + (i + 1), img }));
    slots.push(
      { key: 'about_img_1', label: 'Câu chuyện — ảnh lớn', img: s.about_img_1 },
      { key: 'about_img_2', label: 'Câu chuyện — ảnh trái', img: s.about_img_2 },
      { key: 'about_img_3', label: 'Câu chuyện — ảnh phải', img: s.about_img_3 },
      { key: 'feature_vay_img', label: 'Mục Váy cưới', img: s.feature_vay_img },
      { key: 'feature_phongsu_img', label: 'Mục Phóng sự', img: s.feature_phongsu_img }
    );
    slots.forEach(sl => { sl.pos = s['pos_' + sl.key] || '50% 50%'; });
  %>
  <div class="img-picker-grid">
    <% slots.forEach(sl => { %>
    <form method="post" action="/admin/settings/image" enctype="multipart/form-data" class="img-picker">
      <input type="hidden" name="key" value="<%= sl.key %>" />
      <label title="Bấm để chọn ảnh thay thế">
        <img src="<%= sl.img %>" alt="" loading="lazy" style="object-position:<%= sl.pos %>" id="pk-<%= sl.key %>" />
        <span><%= sl.label %></span>
        <input type="file" name="photo" accept="image/jpeg,image/png,image/webp" onchange="this.form.submit()" hidden />
      </label>
      <div class="pos-ctl" title="Căn phần ảnh hiển thị khi bị cắt: kéo trái = lấy phần trên, kéo phải = lấy phần dưới">
        <span>↑</span>
        <input type="range" min="0" max="100" step="5"
          value="<%= parseInt(sl.pos.split(' ')[1]) || 50 %>"
          data-key="<%= sl.key %>" class="pos-slider" aria-label="Căn vị trí dọc của <%= sl.label %>" />
        <span>↓</span>
      </div>
    </form>
    <% }) %>
  </div>
</div>

<script>
// Căn vị trí ảnh cố định: xem trước ngay trên thumbnail, tự lưu sau khi ngừng kéo 0.4s
document.querySelectorAll('.pos-slider').forEach(sl => {
  let t;
  sl.addEventListener('input', () => {
    const key = sl.dataset.key;
    document.getElementById('pk-' + key).style.objectPosition = '50% ' + sl.value + '%';
    clearTimeout(t);
    t = setTimeout(() => {
      fetch('/admin/settings/image-pos', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ key, x: 50, y: Number(sl.value) })
      }).then(r => { if (r.ok) sl.classList.add('saved'); setTimeout(() => sl.classList.remove('saved'), 900); });
    }, 400);
  });
});
</script>

<h2>Phim cưới (YouTube)</h2>
<div class="panel">
  <% videos.forEach(v => { %>
  <div class="video-row">
    <img src="https://img.youtube.com/vi/<%= v.youtube_id %>/mqdefault.jpg" alt="" loading="lazy" />
    <div class="info"><b><%= v.title %></b><span class="muted"><%= v.youtube_id %></span></div>
    <form method="post" action="/admin/videos/<%= v.id %>/delete" onsubmit="return confirm('Xoá video này?')" class="inline-form">
      <button class="ad-btn danger sm" type="submit">✕</button>
    </form>
  </div>
  <% }) %>
  <form method="post" action="/admin/videos" class="grid-form" style="margin-top:14px">
    <label>Link hoặc ID YouTube <input name="youtube_id" placeholder="https://youtube.com/watch?v=..." required /></label>
    <label>Tiêu đề <input name="title" placeholder="VD: Bên nhau mãi mãi" /></label>
    <button type="submit" class="ad-btn primary">+ Thêm video</button>
  </form>
</div>

<%- include('partials/bottom') %>
