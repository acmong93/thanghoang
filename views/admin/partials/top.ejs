<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="robots" content="noindex, nofollow" />
<title><%= t %> · Quản trị Rosé Wedding</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/css/admin.css" />
</head>
<body>
<div class="layout">
  <aside class="side">
    <div class="side-brand">Rosé <b>Admin</b></div>
    <nav>
      <a href="/admin" class="<%= path === '/' ? 'active' : '' %>">Tổng quan</a>
      <a href="/admin/leads" class="<%= path.startsWith('/leads') ? 'active' : '' %>">Đặt lịch</a>
      <a href="/admin/albums" class="<%= path.startsWith('/albums') ? 'active' : '' %>">Album &amp; Ảnh</a>
      <a href="/admin/vips" class="<%= path.startsWith('/vips') ? 'active' : '' %>">Khách VIP</a>
      <a href="/admin/pricing" class="<%= path.startsWith('/pricing') ? 'active' : '' %>">Bảng giá</a>
      <a href="/admin/posts" class="<%= path.startsWith('/posts') ? 'active' : '' %>">Bài viết</a>
      <a href="/admin/settings" class="<%= path.startsWith('/settings') ? 'active' : '' %>">Cài đặt</a>
    </nav>
    <div class="side-foot">
      <a href="/" target="_blank" rel="noopener">Xem website ↗</a>
      <form method="post" action="/admin/logout"><button type="submit">Đăng xuất (<%= user.username %>)</button></form>
    </div>
  </aside>
  <main class="content">
