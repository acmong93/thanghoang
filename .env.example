# ===== Rosé Wedding — Cấu hình môi trường =====
# Copy file này thành .env rồi điền giá trị thật. KHÔNG commit file .env lên Git.

# Cổng chạy server
PORT=3000

# Khóa mã hóa session (đổi thành chuỗi ngẫu nhiên dài bất kỳ)
SESSION_SECRET=doi-thanh-chuoi-ngau-nhien-dai-va-bi-mat

# Tài khoản quản trị (tạo lần đầu khi khởi động server)
ADMIN_USER=admin
ADMIN_PASSWORD=doi-mat-khau-manh-truoc-khi-deploy

# ===== Email thông báo khi có khách đặt lịch =====
# Dùng Gmail: bật 2FA rồi tạo "App password" tại https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=rosewedding.ceo@gmail.com
SMTP_PASS=
# Email nhận thông báo đặt lịch (có thể trùng SMTP_USER)
NOTIFY_EMAIL=rosewedding.ceo@gmail.com
